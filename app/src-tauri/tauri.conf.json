{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kokoro",
  "mainBinaryName": "kokoro",
  "version": "0.0.19",
  "identifier": "me.nkdr.kokoro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run build:sidecar && bun run dev",
    "beforeBuildCommand": "bun run build:sidecar && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kokoro",
        "width": 800,
        "height": 600,
        "minWidth": 560,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 22,
          "y": 30
        },
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/synthesis/**"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": {
      "../../checkpoints/kokoro-v1.0.onnx": "models/kokoro-v1.0.onnx",
      "../../data/voices-v1.0.bin": "models/voices-v1.0.bin"
    },
    "externalBin": [
      "binaries/koko"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBM0U5OURBOERDMUM5MTAKUldRUXljR04ycGsrV21tb3pwamNDdVZrZVErbWdiRUNvUEI5b2JqMWR3OGpnOFdiUWNkU29uY3EK",
      "endpoints": [
        "https://github.com/nikitadrokin/kokoro/releases/latest/download/latest.json"
      ]
    }
  }
}
