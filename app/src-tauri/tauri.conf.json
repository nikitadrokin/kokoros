{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kokoros",
  "mainBinaryName": "kokoros",
  "version": "0.0.4",
  "identifier": "me.nkdr.kokoros",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run build:sidecar && bun run dev",
    "beforeBuildCommand": "bun run build:sidecar && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kokoro",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../checkpoints/kokoro-v1.0.onnx": "models/kokoro-v1.0.onnx",
      "../../data/voices-v1.0.bin": "models/voices-v1.0.bin"
    },
    "externalBin": [
      "binaries/koko"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
